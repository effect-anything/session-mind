{
  "name": "@effect-x/session-mind",
  "version": "0.1.1",
  "description": "TODO",
  "keywords": [
    "effect",
    "opencode",
    "session"
  ],
  "homepage": "https://github.com/effect-anything/session-mind#readme",
  "bugs": {
    "url": "https://github.com/effect-anything/session-mind/issues"
  },
  "license": "MIT",
  "contributors": [
    "xesrevinu"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/effect-anything/session-mind"
  },
  "bin": {
    "session-mind": "dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "SKILL.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "effect-language-service patch && node ./tools/setup-husky.mjs",
    "test": "vitest --silent 'passed-only'",
    "madge": "madge --circular --ts-config ./tsconfig.json --no-color --no-spinner --extensions 'ts,tsx' ./src",
    "check": "concurrently \"oxlint\" \"tsgo --noEmit\" \"bun run test --watch false\" \"bun run madge\" \"effect-language-service diagnostics --project tsconfig.json\"",
    "fix": "concurrently \"oxlint --fix\" \"oxfmt\"",
    "build": "node ./tools/build-cli.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@effect/language-service": "^0.79.0",
    "@effect/platform-node": "4.0.0-beta.31",
    "@effect/vitest": "4.0.0-beta.31",
    "@types/bun": "^1.3.10",
    "@typescript/native-preview": "7.0.0-dev.20260311.1",
    "concurrently": "^9.2.1",
    "effect": "4.0.0-beta.31",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "madge": "^8.0.0",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,md,yml,yaml}": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=24"
  }
}
